  last_sync_datetime DateTime? @db.DateTime(0)
  user_id            String?   @db.VarChar(32)
  status             Int?      @db.TinyInt
  access_token       String?   @db.Text
  sync_status        Int?      @db.TinyInt
  channel_id         String?   @db.VarChar(255)
