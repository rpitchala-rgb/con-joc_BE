generator client {
  provider = "prisma-client-js"
  output   = "../../../../.prisma/joc-client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL_JOC")
}

model account_activity_log {
  id         Int       @id @default(autoincrement())
  account_id Int
  member_id  Int       @default(0)
  status     String?   @db.VarChar(255)
  action     String?   @db.VarChar(255)
  input      String?   @db.Text
  output     String?   @db.Text
  ip_address String    @db.VarChar(15)
  created_at DateTime  @db.DateTime(0)
  updated_at DateTime? @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)

  @@index([account_id, member_id, status, deleted_at], map: "account_id")
  @@index([ip_address], map: "ip_address")
}

model account_attachment_files {
  id          Int       @id @default(autoincrement())
  account_id  Int
  member_id   Int
  file_id     String    @db.VarChar(255)
  file_name   String    @db.VarChar(255)
  file_type   String    @db.VarChar(255)
  description String?   @db.VarChar(1024)
  created_at  DateTime? @db.DateTime(0)
  updated_at  DateTime? @db.DateTime(0)
  deleted_at  DateTime? @db.DateTime(0)
}

model account_billing {
  id                  Int                     @id @default(autoincrement())
  u_id                String                  @db.VarChar(32)
  account_id          Int
  billing_id          Int?
  type                account_billing_type?   @default(LICENSE)
  billing_cycle       Int?                    @default(28)
  cancellation_period String?                 @db.VarChar(255)
  status              account_billing_status? @default(ACTIVE)
  rate_override       String?                 @db.MediumText
  created_at          DateTime?               @db.DateTime(0)
  updated_at          DateTime?               @db.DateTime(0)
  deleted_at          DateTime?               @db.DateTime(0)

  @@index([account_id], map: "account_id")
  @@index([deleted_at], map: "deleted_at")
}

model account_billing_dev {
  id                  Int                         @id @default(autoincrement())
  u_id                String                      @db.VarChar(32)
  account_id          Int
  billing_id          Int?
  type                account_billing_dev_type?   @default(LICENSE)
  billing_cycle       Int?                        @default(28)
  billing_dev         Int
  cancellation_period String?                     @db.VarChar(255)
  status              account_billing_dev_status? @default(ACTIVE)
  rate_override       String?                     @db.Text
  created_at          DateTime?                   @db.DateTime(0)
  updated_at          DateTime?                   @db.DateTime(0)
  deleted_at          DateTime?                   @db.DateTime(0)
}

model account_contacts {
  id               Int       @id @default(autoincrement())
  u_id             String    @db.VarChar(32)
  account_id       Int
  department       String?   @db.VarChar(255)
  first_name       String?   @db.VarChar(255)
  middle_name      String?   @db.VarChar(255)
  last_name        String?   @db.VarChar(255)
  title            String?   @db.VarChar(255)
  address          String?   @db.VarChar(255)
  address_2        String?   @db.VarChar(255)
  city             String?   @db.VarChar(255)
  state            String?   @db.VarChar(255)
  postal_code      String?   @db.VarChar(10)
  country          String?   @db.VarChar(3)
  phone_office     String?   @db.VarChar(15)
  phone_home       String?   @db.VarChar(15)
  phone_mobile     String?   @db.VarChar(15)
  phone_fax        String?   @db.VarChar(15)
  phone_office_ext String?   @db.VarChar(10)
  phone_home_ext   String?   @db.VarChar(10)
  phone_mobile_ext String?   @db.VarChar(10)
  phone_fax_ext    String?   @db.VarChar(10)
  email            String?   @db.VarChar(255)
  secondary_email  String?   @db.VarChar(255)
  notify           Int?
  comment          String?   @db.VarChar(512)
  created_at       DateTime? @db.DateTime(0)
  updated_at       DateTime? @db.DateTime(0)
  deleted_at       DateTime? @db.DateTime(0)

  @@index([u_id, account_id, created_at], map: "u_id")
}

model account_cyneric {
  id                     Int                            @id @default(autoincrement())
  u_id                   String                         @db.VarChar(32)
  account_id             Int
  cyneric_id             Int?
  type                   account_cyneric_type?          @default(OUTBOUND)
  unlimited              account_cyneric_unlimited?     @default(Y)
  pay_type               Int?                           @default(2)
  balance                Decimal?                       @db.Decimal(10, 4)
  rate                   Int?
  min_start_second       Int?                           @default(0)
  increment_second       Int?                           @default(0)
  dialplan               Int?
  refill_amount          Int?
  refill_trigger_amount  Int?
  max_credit_allowed     Float?
  transaction_retry      Int?                           @default(0)
  transaction_retried_at DateTime?                      @db.DateTime(0)
  status                 account_cyneric_status?        @default(NEW)
  created_at             DateTime?                      @db.DateTime(0)
  updated_at             DateTime?                      @db.DateTime(0)
  deleted_at             DateTime?                      @db.DateTime(0)
  mrm_fund_percent       Int?
  provider_id            Int?                           @default(5)
  provider_type          account_cyneric_provider_type?
  json_settings          String?                        @db.Text

  @@index([account_id], map: "account_id")
  @@index([cyneric_id], map: "cyneric_id")
  @@index([deleted_at], map: "deleted_at")
  @@index([status], map: "status")
  @@index([transaction_retry], map: "transaction_retry")
  @@index([type], map: "type")
}

model account_dialer_settings {
  id                  Int                               @id @default(autoincrement())
  account_id          Int
  subscription_id     String                            @db.VarChar(20)
  dialer_component_id Int
  quantity            Float?
  billable            account_dialer_settings_billable? @default(N)
  created_at          DateTime                          @db.DateTime(0)
  updated_at          DateTime?                         @db.DateTime(0)
  deleted_at          DateTime?                         @db.DateTime(0)

  @@index([account_id], map: "account_id")
  @@index([subscription_id], map: "subscription_id")
}

model account_group_accounts {
  id               Int            @id @default(autoincrement())
  account_group_id Int
  account_id       Int
  created_at       DateTime?      @db.DateTime(0)
  updated_at       DateTime?      @db.DateTime(0)
  deleted_at       DateTime?      @db.DateTime(0)
  account_groups   account_groups @relation(fields: [account_group_id], references: [id])

  @@index([account_group_id], map: "account_group_id")
  @@index([account_id], map: "account_id")
  @@index([deleted_at], map: "deleted_at")
}

model account_group_users {
  id               Int            @id @default(autoincrement())
  account_group_id Int
  from_account_id  Int
  from_user_id     Int
  to_account_id    Int
  to_user_id       Int
  created_at       DateTime?      @db.DateTime(0)
  updated_at       DateTime?      @db.DateTime(0)
  deleted_at       DateTime?      @db.DateTime(0)
  account_groups   account_groups @relation(fields: [account_group_id], references: [id])

  @@index([account_group_id], map: "account_group_id")
  @@index([deleted_at], map: "deleted_at")
  @@index([from_account_id], map: "from_account_id")
  @@index([from_user_id], map: "from_user_id")
  @@index([to_account_id], map: "to_account_id")
  @@index([to_user_id], map: "to_user_id")
}

model account_groups {
  id                   Int                      @id @default(autoincrement())
  name                 String                   @db.VarChar(50)
  description          String?                  @db.VarChar(255)
  status               account_groups_status    @default(INACTIVE)
  created_at           DateTime?                @db.DateTime(0)
  updated_at           DateTime?                @db.DateTime(0)
  deleted_at           DateTime?                @db.DateTime(0)
  accountGroupAccounts account_group_accounts[]
  accountGroupUsers    account_group_users[]

  @@index([deleted_at], map: "deleted_at")
  @@index([status], map: "status")
}

model account_info {
  account_id                  Int                                      @id
  password_complexity         Int
  object_limitation           String?                                  @default("") @db.VarChar(512)
  additional_lead_field       account_info_additional_lead_field?      @default(N)
  preview_dial_restriction    account_info_preview_dial_restriction    @default(N)
  num_free_minutes            Int                                      @default(1000)
  minute_usage                Int?                                     @default(0)
  is_honey_pot                account_info_is_honey_pot?               @default(N)
  tours                       String?                                  @db.VarChar(512)
  is_in_testbed               account_info_is_in_testbed?              @default(N)
  archive_log_after_x_day     String?                                  @db.VarChar(512)
  sale_rep_id                 Int?                                     @default(0)
  backup_sale_rep_id          Int?
  voso_ai_csm_id              Int
  csm_rep_id                  Int                                      @default(0)
  backup_csm_rep_id           Int?                                     @default(0)
  max_channels                Int?                                     @default(0)
  client_tier                 Int                                      @default(4)
  disclaimer                  Bytes?                                   @db.Blob
  log_lead_changes            account_info_log_lead_changes?           @default(N)
  exclude_from_revenue_report account_info_exclude_from_revenue_report @default(N)
  show_tos_on_agent_app       account_info_show_tos_on_agent_app?      @default(N)
  billing_tab_status          account_info_billing_tab_status?         @default(N)
  billing_tab_max             Float?                                   @default(0) @db.Float
  tab_credit                  Float?                                   @default(0.00) @db.Float
  virtual_agent               account_info_virtual_agent?              @default(N)
  preserve_log_expire_at      DateTime?                                @db.DateTime(0)
  json_settings               String?                                  @db.MediumText
  external_service_json       String?                                  @db.Text
  hopper_custom_field_order   account_info_hopper_custom_field_order   @default(N)
  talkdesk_id                 String?                                  @db.VarChar(255)

  @@index([backup_csm_rep_id], map: "backup_csm_rep_id")
  @@index([backup_sale_rep_id], map: "backup_sale_rep_id")
  @@index([csm_rep_id], map: "csm_rep_id")
  @@index([talkdesk_id], map: "idx_talkdesk_id")
  @@index([sale_rep_id], map: "sale_rep_id")
}

model account_info_backup {
  account_id                  Int                                             @id
  password_complexity         Int
  object_limitation           String?                                         @default("") @db.VarChar(512)
  additional_lead_field       account_info_backup_additional_lead_field?      @default(N)
  preview_dial_restriction    account_info_backup_preview_dial_restriction    @default(N)
  num_free_minutes            Int                                             @default(1000)
  minute_usage                Int?                                            @default(0)
  is_honey_pot                account_info_backup_is_honey_pot?               @default(N)
  tours                       String?                                         @db.VarChar(512)
  is_in_testbed               account_info_backup_is_in_testbed?              @default(N)
  archive_log_after_x_day     String?                                         @db.VarChar(512)
  sale_rep_id                 Int?                                            @default(0)
  backup_sale_rep_id          Int?
  voso_ai_csm_id              Int
  csm_rep_id                  Int                                             @default(0)
  backup_csm_rep_id           Int?                                            @default(0)
  max_channels                Int?                                            @default(0)
  client_tier                 Int                                             @default(4)
  disclaimer                  Bytes?                                          @db.Blob
  log_lead_changes            account_info_backup_log_lead_changes?           @default(N)
  exclude_from_revenue_report account_info_backup_exclude_from_revenue_report @default(N)
  show_tos_on_agent_app       account_info_backup_show_tos_on_agent_app?      @default(N)
  billing_tab_status          account_info_backup_billing_tab_status?         @default(N)
  billing_tab_max             Float?                                          @default(0) @db.Float
  tab_credit                  Float?                                          @default(0.00) @db.Float
  virtual_agent               account_info_backup_virtual_agent?              @default(N)
  preserve_log_expire_at      DateTime?                                       @db.DateTime(0)
  json_settings               String?                                         @db.MediumText
  external_service_json       String?                                         @db.Text
  hopper_custom_field_order   account_info_backup_hopper_custom_field_order   @default(N)

  @@index([backup_csm_rep_id], map: "backup_csm_rep_id")
  @@index([backup_sale_rep_id], map: "backup_sale_rep_id")
  @@index([csm_rep_id], map: "csm_rep_id")
  @@index([sale_rep_id], map: "sale_rep_id")
}

model account_notes {
  id         Int       @id @default(autoincrement())
  u_id       String    @db.VarChar(32)
  account_id Int
  member_id  Int?      @default(0)
  subject    String?   @db.VarChar(255)
  note       String?   @db.Text
  created_at DateTime? @db.DateTime(0)
  updated_at DateTime? @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)

  @@index([u_id, account_id, member_id, created_at, deleted_at], map: "u_id")
}

model account_providers {
  id                     Int                          @id @default(autoincrement())
  u_id                   String                       @db.VarChar(32)
  account_id             Int
  provider_id            Int?
  provider_external_id   Int?                         @default(0)
  type                   account_providers_type?      @default(VOICE)
  sub_type               account_providers_sub_type?
  unlimited              account_providers_unlimited? @default(Y)
  pay_type               Int?                         @default(2)
  balance                Decimal?                     @db.Decimal(10, 2)
  rate                   Int?
  min_start_second       Int?                         @default(0)
  increment_second       Int?                         @default(0)
  dialplan               Int?
  refill_amount          Int?
  refill_trigger_amount  Int?
  max_credit_allowed     Float?
  transaction_retry      Int?                         @default(0)
  transaction_retried_at DateTime?                    @db.DateTime(0)
  status                 account_providers_status?    @default(NEW)
  created_at             DateTime?                    @db.DateTime(0)
  updated_at             DateTime?                    @db.DateTime(0)
  deleted_at             DateTime?                    @db.DateTime(0)
  mrm_fund_percent       Int?

  @@index([transaction_retry], map: "transaction_retry")
}

model account_sip_trunks {
  id         Int       @id @default(autoincrement())
  account_id Int
  dial_plan  String?   @db.Text
  peer       String?   @db.Text
  created_at DateTime? @db.DateTime(0)
  updated_at DateTime? @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)
}

model account_talkdesk {
  id               Int                      @id @default(autoincrement())
  account_id       Int?
  talkdesk_id      String                   @db.VarChar(255)
  account_name     String                   @db.VarChar(255)
  app_id           String                   @db.VarChar(255)
  app_version_id   String                   @db.VarChar(255)
  app_version_name String                   @db.VarChar(255)
  client_id        String                   @db.VarChar(255)
  client_secret    String                   @db.VarChar(255)
  event_id         String                   @db.VarChar(255)
  installation_id  String                   @db.VarChar(255)
  key_algorithm    String                   @db.VarChar(255)
  key_id           String                   @db.VarChar(255)
  private_key      String                   @db.VarChar(255)
  public_key       String                   @db.VarChar(255)
  users            String?                  @db.Text
  widget_url       String?                  @db.Text
  status           account_talkdesk_status?
  trial_expires_at DateTime?                @db.DateTime(0)
  created_at       DateTime                 @default(now()) @db.DateTime(0)
  updated_at       DateTime                 @default(now()) @db.DateTime(0)
  deleted_at       DateTime?                @db.DateTime(0)

  @@index([account_id], map: "account_id")
  @@index([deleted_at], map: "deleted_at")
  @@index([status], map: "status")
  @@index([talkdesk_id], map: "talkdesk_id")
}

model accounts {
  id                         Int                                  @id @default(autoincrement())
  u_id                       String                               @db.VarChar(32)
  name                       String                               @db.VarChar(255)
  company_name               String?                              @db.VarChar(255)
  status                     accounts_status                      @default(NEW)
  account_type               accounts_account_type?               @default(REGULAR)
  address                    String?                              @db.VarChar(255)
  address_2                  String?                              @db.VarChar(255)
  city                       String?                              @db.VarChar(255)
  state                      String?                              @db.VarChar(255)
  zipcode                    String?                              @db.VarChar(10)
  country                    String?                              @db.VarChar(255)
  phone                      String?                              @db.VarChar(20)
  website                    String?                              @db.VarChar(255)
  local_gmt                  String?                              @db.VarChar(20)
  registration_server        String?                              @db.VarChar(20)
  master_server              String?                              @db.VarChar(20)
  cluster_node               String?                              @db.VarChar(50)
  billing_id                 Int?
  impersonate_key            String?                              @db.VarChar(255)
  impersonate_expired_at     DateTime?                            @db.DateTime(0)
  default_gmt                String?                              @db.VarChar(10)
  default_caller_id          String?                              @db.VarChar(20)
  demo_expired_at            DateTime?                            @db.DateTime(0)
  extend_delinquent_period   Int                                  @default(1)
  delinquent_at              DateTime?                            @db.DateTime(0)
  minimum_seat               Int
  minimum_seat_expired_at    DateTime?                            @db.Date
  contract_start_date        DateTime?                            @db.Date
  billing_production         accounts_billing_production?         @default(N)
  test_account               accounts_test_account?               @default(N)
  maintenant_start_at        DateTime?                            @db.DateTime(0)
  maintenant_end_at          DateTime?                            @db.DateTime(0)
  dr_account                 accounts_dr_account?                 @default(N)
  dr_account_id              Int                                  @default(0)
  tier                       Int                                  @default(2)
  day_log_keep_in_master     Int                                  @default(3)
  day_log_to_keep            String?                              @db.VarChar(512)
  security_compliance        Int                                  @default(0)
  encryption_key             String?                              @db.Text
  encryption_recipient       String?                              @db.VarChar(255)
  default_audio_format       accounts_default_audio_format?       @default(MP3)
  primary_data_center        accounts_primary_data_center?        @default(DT)
  multi_process              accounts_multi_process?              @default(N)
  multi_process_auto_dial    accounts_multi_process_auto_dial     @default(N)
  verification_code          String?                              @db.VarChar(32)
  license_seat_count         Int?                                 @default(0)
  created_at                 DateTime?                            @db.DateTime(0)
  updated_at                 DateTime?                            @db.DateTime(0)
  inactive_at                DateTime?                            @db.DateTime(0)
  deleted_at                 DateTime?                            @db.DateTime(0)
  billing_system             String?                              @db.VarChar(124)
  migration_mode             String?                              @db.VarChar(10)
  billing_account_id         String?                              @db.VarChar(100)
  z_account_id               String?                              @db.VarChar(100)
  crm_id                     String?                              @db.VarChar(255)
  trr_system                 String?                              @default("9") @db.VarChar(45)
  iva_managed_service        accounts_iva_managed_service?        @default(N)
  externally_managed_account accounts_externally_managed_account? @default(N)
  voip_provider_env          accounts_voip_provider_env?
  host_group_name            String?                              @db.VarChar(255)
  use_hostgroup              Boolean?                             @default(false)
  trr_account_id             Int?

  @@index([delinquent_at], map: "delinquent_at")
  @@index([demo_expired_at], map: "demo_expired_at")
  @@index([primary_data_center], map: "primary_data_center")
  @@index([status], map: "status")
  @@index([u_id, name, company_name], map: "u_id")
}

model acl_paths {
  id                   Int                       @id @default(autoincrement())
  u_id                 String                    @db.VarChar(32)
  section_name         String                    @db.VarChar(255)
  name                 String                    @db.VarChar(255)
  route_name           String                    @db.VarChar(255)
  path                 String                    @db.VarChar(255)
  permission_type      acl_paths_permission_type @default(R)
  minimum_access_level Int?
  created_at           DateTime                  @db.DateTime(0)
  updated_at           DateTime?                 @db.DateTime(0)
  deleted_at           DateTime?                 @db.DateTime(0)

  @@unique([u_id, path], map: "u_id")
  @@index([section_name], map: "parent_id")
}

model acl_paths_polaris {
  id                   Int                               @id @default(autoincrement())
  u_id                 String                            @db.VarChar(32)
  section_name         String                            @db.VarChar(255)
  name                 String                            @db.VarChar(255)
  route_name           String                            @db.VarChar(255)
  path                 String                            @db.VarChar(255)
  permission_type      acl_paths_polaris_permission_type @default(R)
  minimum_access_level Int?
  created_at           DateTime                          @db.DateTime(0)
  updated_at           DateTime?                         @db.DateTime(0)
  deleted_at           DateTime?                         @db.DateTime(0)

  @@unique([u_id, path], map: "u_id")
  @@index([section_name], map: "parent_id")
}

model acl_rules {
  id           Int                   @id @default(autoincrement())
  u_id         String                @unique(map: "u_id") @db.VarChar(32)
  parent_id    Int
  app          String                @db.VarChar(20)
