generator client {
  provider = "prisma-client-js"
  output   = "../../../../.prisma/master-client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL_MAS")
}

model tenant {
  id          String @id @db.VarChar(255)
  name        String @db.VarChar(255)
  dbHost      String @db.VarChar(255)
  dbName      String @db.VarChar(255)
  dbUser      String @db.VarChar(255)
  dbPass      String @db.VarChar(255)
  clusterName String @db.VarChar(100)
}
