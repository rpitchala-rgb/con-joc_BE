generator client {
  provider = "prisma-client-js"
  output   = "../../../../.prisma/asterisk-client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL_ASTERISK")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model users {
  user_id                            Int                                       @unique(map: "USER_ID") @db.UnsignedInt
  u_id                               String                                    @db.VarChar(255)
  account_id                         Int                                       @default(0)
  acl_access_profile                 Int?
  agent_acl_profile                  Int?
  email                              String?                                   @db.VarChar(255)
  first_name                         String?                                   @db.VarChar(50)
  last_name                          String?                                   @db.VarChar(50)
  user_level                         Int?                                      @default(1) @db.TinyInt
  phone_login                        String?                                   @db.VarChar(20)
  phone_pass                         String?                                   @db.VarChar(20)
  hotkeys_active                     users_hotkeys_active?                     @default(dbgenerated("0"))
  agent_choose_ingroups              users_agent_choose_ingroups?              @default(dbgenerated("1"))
  closer_campaigns                   String?                                   @db.Text
  scheduled_callbacks                users_scheduled_callbacks?                @default(dbgenerated("1"))
  agentonly_callbacks                users_agentonly_callbacks?                @default(dbgenerated("0"))
  callback_email_template            String?                                   @db.VarChar(255)
  cost_per_hour                      Float?                                    @db.Float
  agentcall_manual                   users_agentcall_manual?                   @default(dbgenerated("0"))
  recording                          users_recording?                          @default(dbgenerated("1"))
  transfers                          users_transfers?                          @default(dbgenerated("1"))
  closer_default_blended             users_closer_default_blended?             @default(dbgenerated("0"))
  recording_override                 users_recording_override?                 @default(DISABLED)
  alter_custdata_override            users_alter_custdata_override?            @default(N)
  qc_enabled                         users_qc_enabled?                         @default(dbgenerated("0"))
  qc_user_level                      Int?                                      @default(1)
  qc_pass                            users_qc_pass?                            @default(dbgenerated("0"))
  qc_finish                          users_qc_finish?                          @default(dbgenerated("0"))
  qc_commit                          users_qc_commit?                          @default(dbgenerated("0"))
  alter_custphone_override           users_alter_custphone_override?           @default(Y)
  active                             users_active?                             @default(Y)
  alert_enabled                      users_alert_enabled?                      @default(dbgenerated("0"))
  agent_shift_enforcement_override   users_agent_shift_enforcement_override?   @default(DISABLED)
  manager_shift_enforcement_override users_manager_shift_enforcement_override? @default(dbgenerated("0"))
  shift_override_flag                users_shift_override_flag?                @default(dbgenerated("0"))
  local_gmt                          String?                                   @default("-8.00") @db.VarChar(10)
  default_callback_gmt_selection     users_default_callback_gmt_selection?     @default(AGENT)
  release_callbacks_in               Int?
  choose_blended                     String?                                   @db.VarChar(3)
  allowed_campaigns                  String?                                   @db.Text
  chat                               String?                                   @db.Text
  realtime_access                    String?                                   @db.MediumText
  realtime_listen                    users_realtime_listen?
  chat_history                       users_chat_history?
  auto_mode                          users_auto_mode?
  lead_access                        String?                                   @db.VarChar(10)
  notification                       users_notification?
  connection_type                    users_connection_type                     @default(BROWSER)
  connect_using                      users_connect_using?                      @default(LONG_POLLING)
  rtp_timeout                        Int?                                      @default(10)
  did_id                             String?                                   @db.VarChar(25)
  allow_choose_cid                   users_allow_choose_cid                    @default(NO)
  queue_override                     users_queue_override                      @default(USE_CAMPAIGN)
  allow_mobile                       users_allow_mobile                        @default(dbgenerated("0"))
  alter_override                     users_alter_override?                     @default(N)
  last_logged_in                     DateTime?                                 @db.DateTime(0)
  auto_id                            Int                                       @id @default(autoincrement())
  allow_calling_dnc                  users_allow_calling_dnc                   @default(N)
  user_widgets                       String?                                   @db.Text
  allow_agent_to_choose_list         Int                                       @default(1)
  default_list_access_level          Int                                       @default(2)
  default_list_for_new_leads         Int                                       @default(0)
  remote_agent                       users_remote_agent?                       @default(N)
  remote_agent_server_ip             String?                                   @db.VarChar(30)
  remote_agent_campaign_id           Int?
  remote_agent_number                String?                                   @db.VarChar(30)
  avatar                             String?                                   @db.VarChar(255)
  soundboard                         String?                                   @db.Text
  custom_fields                      String?                                   @db.Text
  max_inbound_sms                    Int?
  sms_force_callback_campaign        Int?
  terms                              String?                                   @db.Text
  last_agreed_to_terms_at            DateTime?                                 @db.DateTime(0)
  audio_settings                     String?                                   @db.Text
  force_logout                       Boolean?
  inbound_max_call_count             Int                                       @default(0)
  created_at                         DateTime?                                 @db.DateTime(0)
  updated_at                         DateTime?                                 @db.DateTime(0)
  deleted_at                         DateTime?                                 @db.DateTime(0)
  last_missed_calls_seen_at          DateTime?                                 @db.DateTime(0)

  @@index([deleted_at], map: "deleted_at")
  @@index([email], map: "email")
  @@index([inbound_max_call_count], map: "inbound_max_call_count")
  @@index([last_logged_in], map: "last_logged_in")
  @@index([remote_agent], map: "remote_agent")
  @@index([u_id], map: "u_id")
}

enum users_hotkeys_active {
  HOTKEYS_INACTIVE @map("0")
  HOTKEYS_ACTIVE @map("1")
}

enum users_agent_choose_ingroups {
  CHOOSE_NO @map("0")
  CHOOSE_YES @map("1")
}

enum users_scheduled_callbacks {
  CALLBACKS_DISABLED @map("0")
  CALLBACKS_ENABLED @map("1")
}

enum users_agentonly_callbacks {
  AGENTONLY_NO @map("0")
  AGENTONLY_YES @map("1")
  AGENTONLY_SOME @map("2")
}

enum users_agentcall_manual {
  MANUAL_NO @map("0")
  MANUAL_YES @map("1")
}

enum users_recording {
  RECORDING_OFF @map("0")
  RECORDING_ON @map("1")
}

enum users_transfers {
  TRANSFERS_OFF @map("0")
  TRANSFERS_ON @map("1")
}

enum users_closer_default_blended {
  CLOSER_DEFAULT_OFF @map("0")
  CLOSER_DEFAULT_ON @map("1")
}

enum users_recording_override {
  DISABLED
  NEVER
  ONDEMAND
  ALLCALLS
  ALLFORCE
}

enum users_alter_custdata_override {
  Y
  N
}

enum users_qc_enabled {
  QC_DISABLED @map("0")
  QC_ENABLED @map("1")
}

enum users_qc_pass {
  QC_PASS_NO @map("0")
  QC_PASS_YES @map("1")
}

enum users_qc_finish {
  QC_FINISH_NO @map("0")
  QC_FINISH_YES @map("1")
}

enum users_qc_commit {
  QC_COMMIT_NO @map("0")
  QC_COMMIT_YES @map("1")
}

enum users_alter_custphone_override {
  Y
  N
}

enum users_active {
  Y
  N
}

enum users_alert_enabled {
  ALERT_DISABLED @map("0")
  ALERT_ENABLED @map("1")
}

enum users_agent_shift_enforcement_override {
  DISABLED
  OFF
  START
  ALL
}

enum users_manager_shift_enforcement_override {
  SHIFT_OVERRIDE_NO @map("0")
  SHIFT_OVERRIDE_YES @map("1")
}

enum users_shift_override_flag {
  SHIFT_OVERRIDE_FLAG_NO @map("0")
  SHIFT_OVERRIDE_FLAG_YES @map("1")
}

enum users_default_callback_gmt_selection {
  AGENT
  LEAD
}

enum users_realtime_listen {
  REALTIME_LISTEN_NO @map("0")
  REALTIME_LISTEN_YES @map("1")
}

enum users_chat_history {
  CHAT_HISTORY_NO @map("0")
  CHAT_HISTORY_YES @map("1")
}

enum users_auto_mode {
  AUTO_MODE_NO @map("0")
  AUTO_MODE_YES @map("1")
}

enum users_notification {
  NOTIFICATION_OFF @map("0")
  NOTIFICATION_ON @map("1")
}

enum users_connection_type {
  BROWSER
  EXTERNAL
  DIALIN
  SHARED_EXTENSION
}

enum users_connect_using {
  LONG_POLLING
  SOCKET
}

enum users_allow_choose_cid {
  YES
  NO
}

enum users_queue_override {
  USE_CAMPAIGN
  MATCH
  OVERRIDE
  COMBINE
}

enum users_allow_mobile {
  ZERO @map("0")
  ONE @map("1")
}

enum users_alter_override {
  Y
  N
}

enum users_allow_calling_dnc {
  Y
  N
}

enum users_remote_agent {
  N
  Y
  V
}
