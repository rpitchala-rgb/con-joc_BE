model data_fields {
  id              Int                          @id @default(autoincrement())
  u_id            String                       @db.VarChar(32)
  account_id      Int
  name            String?                      @db.VarChar(255)
  code            String?                      @db.VarChar(255)
  description     String?                      @db.VarChar(255)
  measure_unit    data_fields_measure_unit?    @default(QUANTITY)
  kpi_order       data_fields_kpi_order?       @default(UP)
  kpi_calculation data_fields_kpi_calculation? @default(SUM)
  advanced_config Boolean                      @default(false)
  formula         String?                      @db.Text
  field_map_to    String?                      @db.VarChar(20)
  created_at      DateTime?                    @db.DateTime(0)
  updated_at      DateTime?                    @db.DateTime(0)
  deleted_at      DateTime?                    @db.DateTime(0)

  @@index([field_map_to], map: "field_map_to")
  @@index([u_id, account_id, code, created_at], map: "u_id")
}

