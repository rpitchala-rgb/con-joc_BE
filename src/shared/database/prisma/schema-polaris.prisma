model experience {
  id         Int       @id @default(autoincrement())
  account_id Int
  user_id    Int
  experience Int
  level      Int       @default(1)
  created_at DateTime  @db.DateTime(0)
  updated_at DateTime? @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)
}

model group_users {
  id         Int       @id @default(autoincrement())
  group_id   Int
  user_id    Int
  created_at DateTime  @db.DateTime(0)
  updated_at DateTime? @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)

  @@index([group_id, user_id, created_at], map: "group_id")
}

model groups {
  id          Int       @id @default(autoincrement())
  u_id        String    @db.VarChar(32)
  account_id  Int
  name        String    @db.VarChar(255)
  description String    @db.VarChar(255)
  created_by  Int
  created_at  DateTime  @db.DateTime(0)
  updated_at  DateTime? @db.DateTime(0)
  deleted_at  DateTime? @db.DateTime(0)

  @@index([account_id, name, created_by], map: "account_id")
  @@index([u_id], map: "u_id")
}

model karma_levels {
  id         Int       @id @default(autoincrement())
  u_id       String    @db.VarChar(32)
  account_id Int
  level      String    @db.VarChar(255)
  point      Int
  color      String    @db.VarChar(255)
  created_at DateTime? @db.DateTime(0)
  updated_at DateTime? @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)

  @@index([u_id, account_id, created_at], map: "u_id")
}

model karma_point_logs {
  id            Int       @id @default(autoincrement())
  user_id       Int
  karma_type_id Int
  point         Int?
  created_at    DateTime? @db.DateTime(0)
  updated_at    DateTime? @db.DateTime(0)
  deleted_at    DateTime? @db.DateTime(0)

  @@index([user_id, karma_type_id, created_at], map: "user_id")
}

model karma_points {
  id            Int                       @id @default(autoincrement())
  u_id          String                    @db.VarChar(32)
  account_id    Int
  karma_type_id Int
  point         Int?
  accumulable   karma_points_accumulable? @default(N)
  created_at    DateTime?                 @db.DateTime(0)
  updated_at    DateTime?                 @db.DateTime(0)
  deleted_at    DateTime?                 @db.DateTime(0)

  @@index([accumulable], map: "accumulable")
  @@index([u_id, account_id, karma_type_id, created_at], map: "u_id")
}

model karma_types {
  id          Int       @id @default(autoincrement())
  u_id        String    @db.VarChar(32)
  account_id  Int
  action      String    @db.VarChar(255)
  name        String?   @db.VarChar(255)
  description String?   @db.Text
  created_at  DateTime? @db.DateTime(0)
  updated_at  DateTime? @db.DateTime(0)
  deleted_at  DateTime? @db.DateTime(0)

  @@index([u_id, action], map: "u_id")
}

