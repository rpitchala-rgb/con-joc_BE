generator client {
  provider = "prisma-client-js"
  output   = "../../../../.prisma/polaris-client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL_POL")
}

model accounts {
  id                     Int             @id @default(autoincrement())
  u_id                   String          @db.VarChar(32)
  external_account_id    Int
  name                   String          @db.VarChar(255)
  company_name           String?         @db.VarChar(255)
  address                String?         @db.VarChar(255)
  address_2              String?         @db.VarChar(255)
  city                   String?         @db.VarChar(255)
  state                  String?         @db.VarChar(255)
  zipcode                String?         @db.VarChar(10)
  country                String?         @db.VarChar(255)
  phone                  String?         @db.VarChar(20)
  website                String?         @db.VarChar(255)
  local_gmt              String?         @db.VarChar(20)
  cluster_node           String?         @db.VarChar(50)
  site_id                Int?
  billing_id             Int?
  status                 accounts_status @default(NEW)
  impersonate_key        String?         @db.VarChar(255)
  impersonate_expired_at DateTime?       @db.DateTime(0)
  created_at             DateTime?       @db.DateTime(0)
  updated_at             DateTime?       @db.DateTime(0)
  deleted_at             DateTime?       @db.DateTime(0)

  @@index([site_id], map: "site_id")
  @@index([status], map: "status")
  @@index([u_id, name, company_name], map: "u_id")
}

model acl_access_profile {
  id           Int                             @id @default(autoincrement())
  profile_id   Int
  section_name String                          @db.VarChar(255)
  allow_read   acl_access_profile_allow_read   @default(YES)
  allow_write  acl_access_profile_allow_write  @default(YES)
  allow_delete acl_access_profile_allow_delete @default(YES)
  created_at   DateTime                        @db.DateTime(0)
  updated_at   DateTime?                       @db.DateTime(0)
  deleted_at   DateTime?                       @db.DateTime(0)
  account_id   Int

  @@index([section_name], map: "acl_id")
  @@index([profile_id], map: "profile_id")
}

model acl_access_profile_main {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(255)
  created_at DateTime  @db.DateTime(0)
  updated_at DateTime? @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)
  account_id Int
}

model assets {
  id                 Int          @id @default(autoincrement())
  account_id         Int
  user_id            Int
  type               assets_type? @default(ICON)
  original_filename  String?      @db.VarChar(255)
  original_extension String?      @db.VarChar(255)
  mime_type          String?      @db.VarChar(50)
  file_size          Int?
  url                String?      @db.VarChar(255)
  path               String?      @db.VarChar(255)
  cuts               String?      @db.Text
  created_at         DateTime     @db.DateTime(0)
  updated_at         DateTime?    @db.DateTime(0)
  deleted_at         DateTime?    @db.DateTime(0)
}

model award_queue {
  id          Int                  @id @default(autoincrement())
  account_id  Int
  users_id    Int
  description String?              @db.Text
  claimed     award_queue_claimed? @default(NO)
  type_id     Int
  type        award_queue_type?    @default(LEVEL)
  created_at  DateTime             @db.DateTime(0)
  updated_at  DateTime?            @db.DateTime(0)
  deleted_at  DateTime?            @db.DateTime(0)
}

model bets {
  id           Int               @id @default(autoincrement())
  account_id   Int
  name         String?           @db.VarChar(255)
  ticket_price Int
  description  String?           @db.Text
  deadline     DateTime?         @db.DateTime(0)
  options      String            @db.Text
  icon         String?           @db.Text
  distributed  bets_distributed? @default(NO)
  created_at   DateTime          @db.DateTime(0)
  updated_at   DateTime?         @db.DateTime(0)
  deleted_at   DateTime?         @db.DateTime(0)
}

model campaign_kpis {
  id               Int                   @id @default(autoincrement())
  campaign_id      Int
  kpi_id           Int
  goal_daily       Float?
  goal_weekly      Float?
  goal_monthly     Float?
  goal_quarterly   Float?
  goal_semi_annual Float?
  goal_annual      Float?
  weight           Int?
  status           campaign_kpis_status? @default(Y)
  created_at       DateTime?             @db.DateTime(0)
  updated_at       DateTime?             @db.DateTime(0)
  deleted_at       DateTime?             @db.DateTime(0)

  @@index([campaign_id, kpi_id], map: "campaign_id")
}

model campaign_users {
  id            Int       @id @default(autoincrement())
  campaign_id   Int
  user_id       Int
  user_group_id Int?
  created_at    DateTime  @db.DateTime(0)
  updated_at    DateTime? @db.DateTime(0)
  deleted_at    DateTime? @db.DateTime(0)

  @@index([campaign_id, user_id, user_group_id, created_at], map: "campaign_id")
  @@index([deleted_at], map: "deleted_at")
}

model campaigns {
  id                Int                    @id @default(autoincrement())
  u_id              String                 @db.VarChar(32)
  account_id        Int
  name              String                 @db.VarChar(255)
  type              String?                @db.VarChar(255)
  manage_by         Int?
  coaching_goals    Int?
  recognition_goals Int?
  default_goal      campaigns_default_goal @default(goal_daily)
  minimum_weight    Int
  start_date        DateTime?              @db.Date
  end_date          DateTime?              @db.Date
  created_at        DateTime?              @db.DateTime(0)
  updated_at        DateTime?              @db.DateTime(0)
  deleted_at        DateTime?              @db.DateTime(0)

  @@index([u_id, name, created_at], map: "u_id")
}

model certifications {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(255)
  requirement String?   @db.Text
  avatar      String?   @db.Text
  description String?   @db.Text
  created_at  DateTime  @db.DateTime(0)
  updated_at  DateTime? @db.DateTime(0)
  deleted_at  DateTime? @db.DateTime(0)
  account_id  Int
}

model challenges {
  id           Int                      @id @default(autoincrement())
  account_id   Int
  criteria     String?                  @db.Text
  users_id     String?                  @db.Text
  creator_id   Int?
  work_related challenges_work_related? @default(NO)
  name         String                   @db.VarChar(255)
  description  String?                  @db.Text
  icon         String?                  @db.VarChar(255)
  price        Int?
  accept_by    DateTime?                @db.DateTime(0)
  end_date     DateTime?                @db.DateTime(0)
  done         challenges_done?         @default(NO)
  created_at   DateTime                 @db.DateTime(0)
  updated_at   DateTime?                @db.DateTime(0)
  deleted_at   DateTime?                @db.DateTime(0)
}

model courses {
  id                  Int                  @id @default(autoincrement()) @db.UnsignedInt
  u_id                String?              @db.VarChar(32)
  account_id          Int
  session_ids         String?              @db.Text
  user_ids            String?              @db.Text
  name                String?              @db.VarChar(255)
  description         String?              @db.VarChar(255)
  percentage_approval Int?
  tags                String?              @db.Text
  enable_timer        courses_enable_timer @default(N)
  cover_images        String?              @db.Text
  created_at          DateTime?            @db.DateTime(0)
  updated_at          DateTime?            @db.DateTime(0)
  deleted_at          DateTime?            @db.DateTime(0)
}

