generator client {
  provider = "prisma-client-js"
  output   = "../../../../.prisma/asterisk-client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL_AS")
}

model account_config {
  id             Int                 @id @default(autoincrement()) @db.UnsignedInt
  u_id           String              @db.VarChar(32)
  code           String              @db.VarChar(255)
  title          String              @db.VarChar(255)
  description    String?             @db.VarChar(255)
  type           account_config_type @default(boolean)
  sort_order     Int?
  select_options String              @db.VarChar(256)
  validation     String?             @db.VarChar(255)
  created_at     DateTime            @db.DateTime(0)
  updated_at     DateTime?           @db.DateTime(0)
  deleted_at     DateTime?           @db.DateTime(0)
}

model account_config_to_context {
  id           Int       @id @default(autoincrement()) @db.UnsignedInt
  u_id         String    @db.VarChar(32)
  config_id    Int       @db.UnsignedInt
  account_id   Int
  config_value String    @db.Text
  created_at   DateTime  @db.DateTime(0)
  updated_at   DateTime? @db.DateTime(0)
  deleted_at   DateTime? @db.DateTime(0)

  @@index([account_id], map: "account_id")
  @@index([deleted_at], map: "deleted_at")
}

model account_monitor_alerts {
  id                 Int      @id @default(autoincrement()) @db.UnsignedInt
  account_monitor_id Int      @db.UnsignedInt
  account_id         Int      @db.UnsignedInt
  campaign_id        Int      @db.UnsignedInt
  user_id            Int      @db.UnsignedInt
  type               String   @db.VarChar(20)
  message            String?  @default("") @db.VarChar(255)
  email_sent_to      String?  @default("") @db.VarChar(255)
  sms_sent_to        String?  @default("") @db.VarChar(255)
  is_resolved        Boolean  @default(false)
  data               String?  @db.Text
  created_at         DateTime @db.DateTime(0)

  @@index([account_id], map: "account_id")
  @@index([account_monitor_id], map: "account_monitor_id")
}

model account_monitor_logs {
  id                Int      @id @default(autoincrement()) @db.UnsignedInt
  account_id        Int      @db.UnsignedInt
  campaign_id       Int      @db.UnsignedInt
  dial_level        String   @db.VarChar(10)
  hopper            Int
  calls_placed      Int
  calls_ringing     Int
  calls_today       Int
  calls_waiting_in  Int
  calls_waiting_out Int
  dialable_leads    Int
  agent_dead        Int
  agent_dispo       Int
  agent_incall      Int
  agent_paused      Int
  agent_ready       Int
  agent_total       Int
  created_at        DateTime @db.DateTime(0)

  @@index([account_id], map: "account_id")
  @@index([account_id, campaign_id, created_at], map: "account_id_campaign_id_created_at")
}

model account_monitors {
  id           Int       @id @default(autoincrement()) @db.UnsignedInt
  account_id   Int       @db.UnsignedInt
  user_id      Int       @db.UnsignedInt
  campaign_ids String    @db.VarChar(255)
  settings     String    @db.Text
  is_triggered Boolean   @default(false)
  triggered_at DateTime? @db.DateTime(0)
  is_active    Boolean?
  created_at   DateTime  @db.DateTime(0)
  updated_at   DateTime? @db.DateTime(0)

  @@index([account_id], map: "account_id")
  @@index([user_id], map: "user_id")
}

model account_talkdesk {
  id               Int                      @id @default(autoincrement())
  account_id       Int?
  talkdesk_id      String                   @db.VarChar(255)
  account_name     String                   @db.VarChar(255)
  app_id           String                   @db.VarChar(255)
  app_version_id   String                   @db.VarChar(255)
  app_version_name String                   @db.VarChar(255)
  client_id        String                   @db.VarChar(255)
  client_secret    String                   @db.VarChar(255)
  event_id         String                   @db.VarChar(255)
  installation_id  String                   @db.VarChar(255)
  key_algorithm    String                   @db.VarChar(255)
  key_id           String                   @db.VarChar(255)
  private_key      String                   @db.VarChar(255)
  public_key       String                   @db.VarChar(255)
  widget_url       String?                  @db.Text
  status           account_talkdesk_status?
  trial_expires_at DateTime?                @db.DateTime(0)
  created_at       DateTime                 @default(now()) @db.DateTime(0)
  updated_at       DateTime                 @default(now()) @db.DateTime(0)
  deleted_at       DateTime?                @db.DateTime(0)

  @@index([account_id], map: "account_id")
  @@index([deleted_at], map: "deleted_at")
  @@index([status], map: "status")
  @@index([talkdesk_id], map: "talkdesk_id")
}

model acl_access_profile {
  id           Int                             @id @default(autoincrement())
  profile_id   Int
  section_name String                          @db.VarChar(255)
  allow_read   acl_access_profile_allow_read   @default(YES)
  allow_write  acl_access_profile_allow_write  @default(YES)
  allow_delete acl_access_profile_allow_delete @default(YES)
  created_at   DateTime                        @db.DateTime(0)
  updated_at   DateTime?                       @db.DateTime(0)
  deleted_at   DateTime?                       @db.DateTime(0)
  account_id   Int

  @@index([section_name], map: "acl_id")
  @@index([profile_id], map: "profile_id")
}

model acl_access_profile_main {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(255)
  created_at DateTime  @db.DateTime(0)
  updated_at DateTime? @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)
  account_id Int
}

model acl_paths {
  id                   Int                       @id @default(autoincrement())
  u_id                 String                    @db.VarChar(32)
  section_name         String                    @db.VarChar(255)
  name                 String                    @db.VarChar(255)
  route_name           String                    @db.VarChar(255)
  path                 String                    @db.VarChar(255)
  permission_type      acl_paths_permission_type @default(R)
  minimum_access_level Int?
  created_at           DateTime                  @db.DateTime(0)
  updated_at           DateTime?                 @db.DateTime(0)
  deleted_at           DateTime?                 @db.DateTime(0)

  @@unique([u_id, path], map: "u_id")
  @@index([section_name], map: "parent_id")
}

model acl_rules {
  id           Int                   @id @default(autoincrement())
  u_id         String                @unique(map: "u_id") @db.VarChar(32)
  parent_id    Int
  app          String                @db.VarChar(20)
  name         String                @db.VarChar(255)
  section_name String                @db.VarChar(255)
  require_acl  acl_rules_require_acl @default(NO)
  created_at   DateTime              @db.DateTime(0)
  updated_at   DateTime?             @db.DateTime(0)
  deleted_at   DateTime?             @db.DateTime(0)

  @@index([parent_id], map: "parent_id")
}

model adaptors {
  id                 Int                   @unique(map: "id") @default(autoincrement())
  u_id               String                @db.VarChar(32)
  account_id         Int
  name               String                @db.VarChar(255)
  field_relations    String?               @db.Text
  extra_relations    String?               @db.Text
  call_log_relations String?               @db.Text
  active             adaptors_active       @default(YES)
  object_type        adaptors_object_type  @default(LEAD)
  plugin_id          Int?
  created_at         DateTime?             @db.DateTime(0)
  modified_at        DateTime?             @db.DateTime(0)
  deleted_at         DateTime?             @db.DateTime(0)
  adaptor_type       adaptors_adaptor_type @default(OTHER)
}

model admin_log {
  id                Int               @id @default(autoincrement())
  member_id         Int               @default(0)
  ip_address        String            @db.VarChar(20)
  created_at        DateTime          @db.DateTime(0)
  account_id        Int
  user_id           Int
  impersonated_from Int               @default(0)
  section           String?           @db.VarChar(100)
  sub_section       String?           @db.VarChar(100)
  action            admin_log_action? @default(SAVE)
  altered           String?           @db.VarChar(100)
  data              String?           @db.MediumText
  original_data     String?           @db.MediumText
  utc_created_at    DateTime?         @db.DateTime(0)

  @@index([ip_address, created_at, account_id, user_id, section, sub_section, action, altered], map: "ip_address")
}

model admin_log_params {
  id         Int      @id @default(autoincrement()) @db.UnsignedInt
  action     String?  @db.VarChar(100)
  data       String?  @db.MediumText
  created_at DateTime @default(now()) @db.Timestamp(0)

  @@index([action], map: "idx_action")
}

model advanced_lead_filters {
  id          Int                           @id @default(autoincrement())
  u_id        String                        @db.VarChar(32)
  account_id  Int
  name        String?                       @db.VarChar(512)
  campaign_id Int?
  data        String?                       @db.MediumText
  sql_string  String?                       @db.MediumText
  status      advanced_lead_filters_status? @default(Y)
  created_at  DateTime?                     @db.DateTime(0)
  updated_at  DateTime?                     @db.DateTime(0)
  deleted_at  DateTime?                     @db.DateTime(0)

  @@index([account_id], map: "account_id")
  @@index([u_id, campaign_id, status, created_at, deleted_at], map: "u_id")
}

model advanced_lead_recycle {
  recycle_id        Int                           @id @default(autoincrement()) @db.UnsignedInt
  campaign_id       String?                       @default("0") @db.VarChar(8)
  list_id           Int?                          @default(0)
  status            String                        @db.VarChar(6)
  attempt_delay     Int?                          @default(1800) @db.UnsignedInt
  from_called_count Int?                          @default(0) @db.UnsignedInt
  to_called_count   Int?                          @default(0)
  hopper_priority   Int?                          @default(-1)
  active            advanced_lead_recycle_active? @default(Y)
  created_at        DateTime?                     @db.DateTime(0)
  updated_at        DateTime?                     @db.DateTime(0)
  deleted_at        DateTime?                     @db.DateTime(0)

  @@index([campaign_id], map: "campaign_id")
  @@index([deleted_at], map: "deleted_at")
  @@index([list_id], map: "list_id")
  @@index([status, campaign_id], map: "status")
}

model agent_acl {
  id         Int       @id @default(autoincrement()) @db.UnsignedInt
  acl_key    String    @db.VarChar(255)
  value      String?   @db.VarChar(255)
  created_at DateTime  @db.DateTime(0)
  updated_at DateTime? @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)
  user_id    Int
}

model agent_acl_profile {
  id         Int       @id @default(autoincrement()) @db.UnsignedInt
  profile_id Int
  acl_key    String    @db.VarChar(255)
  value      String?   @db.VarChar(255)
  created_at DateTime  @db.DateTime(0)
  updated_at DateTime? @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)
}

model agent_acl_profile_main {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(255)
  created_at DateTime  @db.DateTime(0)
  updated_at DateTime? @db.DateTime(0)
  deleted_at DateTime? @db.DateTime(0)
  account_id Int
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model agent_ai_log {
  id                       Int       @id @default(autoincrement()) @db.UnsignedInt
  campaign_id              Int?
  user_id                  Int?
  lead_id                  Int?      @db.UnsignedInt
  log_id                   BigInt?   @db.UnsignedBigInt
  connection_id            String?   @db.VarChar(64)
  conversation_id          String?   @db.VarChar(64)
  start_timestamp          BigInt?
  trackers_activated       String?   @db.VarChar(256)
  tokens                   Int?      @db.UnsignedSmallInt
  transcripts              String?   @db.MediumText
  trackers                 String?   @db.Text
  suggestions              String?   @db.Text
  agent_negative_sentiment Int?
  lead_negative_sentiment  Int?
  events                   String?   @db.Text
  created_at               DateTime? @default(now()) @db.DateTime(0)

  @@index([campaign_id], map: "campaign_id")
  @@index([agent_negative_sentiment], map: "idx_agent_negative_sentiment")
  @@index([lead_negative_sentiment], map: "idx_lead_negative_sentiment")
}

model agent_log {
  agent_log_id  Int       @id @default(autoincrement()) @db.UnsignedInt
  user_id       Int?
  call_log_id   BigInt?
  server_ip     String    @db.VarChar(15)
  event_time    DateTime? @db.DateTime(0)
  lead_id       Int?      @db.UnsignedInt
  campaign_id   String?   @db.VarChar(8)
  list_id       Int
  pause_epoch   Int?      @db.UnsignedInt
  pause_sec     Int?      @default(0) @db.UnsignedSmallInt
  wait_epoch    Int?      @db.UnsignedInt
  wait_sec      Int?      @default(0) @db.UnsignedSmallInt
  talk_epoch    Int?      @db.UnsignedInt
  talk_sec      Int?      @default(0) @db.UnsignedSmallInt
  dispo_epoch   Int?      @db.UnsignedInt
  dispo_sec     Int?      @default(0) @db.UnsignedSmallInt
  status        String?   @db.VarChar(6)
  comments      String?   @db.VarChar(20)
  sub_status    String?   @db.VarChar(6)
  paused_status String    @db.VarChar(20)
  queue_id      Int?
  call_type     String?   @db.VarChar(20)

  @@index([campaign_id], map: "campaign_id")
  @@index([event_time], map: "event_time")
  @@index([lead_id], map: "lead_id")
  @@index([list_id], map: "list_id")
  @@index([paused_status], map: "paused_status")
  @@index([event_time, user_id], map: "time_user")
  @@index([user_id], map: "user")
  @@index([event_time, user_id, pause_sec, wait_sec, talk_sec, dispo_sec, call_type], map: "user_stats")
}

model agent_monitor_log {
  id         Int                      @id @default(autoincrement())
  account_id Int
  user_id    Int
  agent_id   Int
  lead_id    Int
  action     agent_monitor_log_action @default(LISTEN)
  duration   Int
  created_at DateTime?                @db.DateTime(0)
  updated_at DateTime?                @db.DateTime(0)
  deleted_at DateTime?                @db.DateTime(0)

  @@index([account_id, user_id, agent_id, lead_id, action, duration], map: "account_id")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model agent_sph {
  campaign_group_id String          @db.VarChar(20)
  stat_date         DateTime        @db.Date
  shift             String          @db.VarChar(20)
  role              agent_sph_role? @default(FRONTER)
  user              String          @db.VarChar(20)
  calls             Int?            @default(0) @db.UnsignedMediumInt
  sales             Int?            @default(0) @db.UnsignedMediumInt
  login_sec         Int?            @default(0) @db.UnsignedMediumInt
  login_hours       Decimal?        @default(0.00) @db.Decimal(5, 2)
  sph               Decimal?        @default(0.00) @db.Decimal(6, 2)

  @@index([campaign_group_id], map: "campaign_group_id")
  @@index([stat_date], map: "stat_date")
  @@ignore
}

model agi_did_test {
  id              Int      @id @default(autoincrement())
