model queues_config {
  extension         String   @id @default("") @db.VarChar(20)
  descr             String   @default("") @db.VarChar(35)
  grppre            String   @default("") @db.VarChar(100)
  alertinfo         String   @default("") @db.VarChar(254)
  ringing           Boolean  @default(false)
  maxwait           String   @default("") @db.VarChar(8)
  password          String   @default("") @db.VarChar(20)
  ivr_id            String   @default("0") @db.VarChar(8)
  dest              String   @default("") @db.VarChar(50)
  cwignore          Boolean  @default(false)
  queuewait         Boolean? @default(false)
  use_queue_context Boolean? @default(false)
  togglehint        Boolean? @default(false)
  qnoanswer         Boolean? @default(false)
  callconfirm       Boolean? @default(false)
  callconfirm_id    Int?
  qregex            String?  @db.VarChar(255)
  agentannounce_id  Int?
  joinannounce_id   Int?
  monitor_type      String?  @db.VarChar(5)
  monitor_heard     Int?
  monitor_spoken    Int?
}

model queues_details {
  id      String @default("-1") @db.VarChar(45)
  keyword String @default("") @db.VarChar(30)
  data    String @default("") @db.VarChar(150)
  flags   Int    @default(0)

  @@id([id, keyword, data])
}

model recordings {
  id          Int      @id @default(autoincrement())
  displayname String?  @db.VarChar(50)
  filename    Bytes?   @db.Blob
  description String?  @db.VarChar(254)
  fcode       Boolean? @default(false)
  fcode_pass  String?  @db.VarChar(20)
}

model ringgroups {
  grpnum         String  @id @db.VarChar(20)
  strategy       String  @db.VarChar(50)
  grptime        Int     @db.SmallInt
  grppre         String? @db.VarChar(100)
  grplist        String  @db.VarChar(255)
  annmsg_id      Int?
  postdest       String? @db.VarChar(255)
  description    String  @db.VarChar(35)
  alertinfo      String? @db.VarChar(255)
  remotealert_id Int?
  needsconf      String? @db.VarChar(10)
  toolate_id     Int?
  ringing        String? @db.VarChar(80)
  cwignore       String? @db.VarChar(10)
  cfignore       String? @db.VarChar(10)
  cpickup        String? @db.VarChar(10)
  recording      String? @default("dontcare") @db.VarChar(10)
}

model setcid {
  cid_id      Int     @id @default(autoincrement())
  cid_name    String? @db.VarChar(150)
  cid_num     String? @db.VarChar(150)
  description String? @db.VarChar(50)
  dest        String? @db.VarChar(255)
}

model sip {
  id      String @default("-1") @db.VarChar(20)
  keyword String @default("") @db.VarChar(30)
  data    String @db.VarChar(255)
  flags   Int    @default(0)

  @@id([id, keyword])
}

model sipsettings {
  keyword String  @default("") @db.VarChar(50)
  data    String  @default("") @db.VarChar(255)
  seq     Boolean @default(false)
  type    Boolean @default(false)

  @@id([keyword, seq, type])
}

model timeconditions {
  timeconditions_id Int      @id @default(autoincrement())
  displayname       String?  @db.VarChar(50)
  time              Int?
  truegoto          String?  @db.VarChar(50)
  falsegoto         String?  @db.VarChar(50)
  deptname          String?  @db.VarChar(50)
  generate_hint     Boolean? @default(false)
  priority          String?  @db.VarChar(50)
  context           String   @db.VarChar(50)
}

model timegroups_details {
  id          Int    @id @default(autoincrement())
  timegroupid Int    @default(0)
  time        String @default("") @db.VarChar(100)
}

model timegroups_groups {
  id          Int    @id @default(autoincrement())
  description String @default("") @db.VarChar(50)
  context     String @db.VarChar(255)
}

model trunk_dialpatterns {
  trunkid              Int    @default(0)
  match_pattern_prefix String @default("") @db.VarChar(50)
  match_pattern_pass   String @default("") @db.VarChar(50)
  prepend_digits       String @default("") @db.VarChar(50)
  seq                  Int    @default(0)

  @@id([trunkid, match_pattern_prefix, match_pattern_pass, prepend_digits, seq])
}

model trunks {
  trunkid       Int     @default(0)
  name          String  @default("") @db.VarChar(50)
  tech          String  @db.VarChar(20)
  outcid        String  @default("") @db.VarChar(40)
  keepcid       String? @default("off") @db.VarChar(4)
  maxchans      String? @default("") @db.VarChar(6)
  failscript    String  @default("") @db.VarChar(255)
  dialoutprefix String  @default("") @db.VarChar(255)
  channelid     String  @default("") @db.VarChar(255)
  usercontext   String? @db.VarChar(255)
  provider      String? @db.VarChar(40)
  disabled      String? @default("off") @db.VarChar(4)
  continue      String? @default("off") @db.VarChar(4)

  @@id([trunkid, tech, channelid])
}

model ttsengines {
  id   Int     @id @default(autoincrement())
  name String? @db.VarChar(50)
  path String? @db.VarChar(255)
}

model users {
  extension        String  @default("") @db.VarChar(20)
  password         String? @db.VarChar(20)
  name             String? @db.VarChar(50)
  voicemail        String? @db.VarChar(50)
  ringtimer        Int?
  noanswer         String? @db.VarChar(100)
  recording        String? @db.VarChar(50)
  outboundcid      String? @db.VarChar(255)
  sipname          String? @db.VarChar(50)
  noanswer_cid     String  @default("") @db.VarChar(20)
  busy_cid         String  @default("") @db.VarChar(20)
  chanunavail_cid  String  @default("") @db.VarChar(20)
  noanswer_dest    String  @default("") @db.VarChar(255)
  busy_dest        String  @default("") @db.VarChar(255)
  chanunavail_dest String  @default("") @db.VarChar(255)
  mohclass         String? @default("default") @db.VarChar(80)
  uid              Int     @id @default(autoincrement())

  @@index([voicemail], map: "voice_mail")
}

model vmblast {
  grpnum      Int    @id
  description String @db.VarChar(35)
  audio_label Int    @default(-1)
  password    String @db.VarChar(20)
}

model vmblast_groups {
  grpnum String @default("") @db.VarChar(50)
  ext    String @default("") @db.VarChar(25)

  @@id([grpnum, ext])
}

model voicemail_admin {
  variable String @id @default("") @db.VarChar(30)
  value    String @default("") @db.VarChar(80)
}

model webrtc_clients {
  user      String @unique(map: "user") @db.VarChar(255)
  device    String @unique(map: "device") @db.VarChar(255)
  realm     String @db.VarChar(80)
  username  String @db.VarChar(80)
  sipuri    String @db.VarChar(80)
  password  String @db.VarChar(80)
  websocket String @db.VarChar(80)
  breaker   String @db.VarChar(80)
  cid       String @db.VarChar(80)
  uid       Int    @id @default(autoincrement())
}

model webrtc_settings {
  key   String @unique(map: "key") @db.VarChar(255)
  value String @db.Text
  uid   Int    @id @default(autoincrement())
}

enum freepbx_log_level {
  error
  warning
  debug
  devel_debug @map("devel-debug")
}

enum directory_details_projectx_global {
   ZERO @map("0")
   ONE @map("1")
}
