generator client {
  provider = "prisma-client-js"
  output   = "../../../../.prisma/freepbx-client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL_FBX")
}

model admin {
  variable String @id @default("") @db.VarChar(20)
  value    String @default("") @db.VarChar(80)
}

model ampusers {
  username       String @id @db.VarChar(255)
  password_sha1  String @db.VarChar(40)
  extension_low  String @default("") @db.VarChar(20)
  extension_high String @default("") @db.VarChar(20)
  deptname       String @default("") @db.VarChar(20)
  sections       Bytes  @db.Blob
}

model announcement {
  announcement_id Int     @id @default(autoincrement())
  description     String? @db.VarChar(50)
  recording_id    Int?
  allow_skip      Int?
  post_dest       String? @db.VarChar(255)
  return_ivr      Boolean @default(false)
  noanswer        Boolean @default(false)
  repeat_msg      String  @default("") @db.VarChar(2)
  context         String  @db.VarChar(255)
}

model backup {
  id          Int     @id @default(autoincrement())
  name        String? @db.VarChar(50)
  description String? @db.VarChar(255)
  immortal    String? @db.VarChar(25)
  data        String? @db.LongText
}

model backup_cache {
  id       String  @id @unique(map: "id") @db.VarChar(50)
  manifest String? @db.LongText
}

model backup_details {
  backup_id Int
  key       String? @db.VarChar(50)
  index     String? @db.VarChar(25)
  value     String? @db.VarChar(250)
  uid       Int     @id @default(autoincrement())
}

model backup_items {
  backup_id Int
  type      String? @db.VarChar(50)
  path      String? @db.Text
  exclude   String? @db.Text
  uid       Int     @id @default(autoincrement())
}

model backup_server_details {
  server_id Int
  key       String? @db.VarChar(50)
  value     String? @db.VarChar(250)
  uid       Int     @id @default(autoincrement())
}

model backup_servers {
  id       Int     @id @default(autoincrement())
  name     String? @db.VarChar(50)
  desc     String? @db.VarChar(255)
  type     String? @db.VarChar(50)
  readonly String? @db.VarChar(250)
  immortal String? @db.VarChar(25)
  data     String? @db.LongText
}

model backup_template_details {
  template_id Int
  type        String? @db.VarChar(50)
  path        String? @db.Text
  exclude     String? @db.Text
  uid         Int     @id @default(autoincrement())
}

model backup_templates {
  id       Int     @id @default(autoincrement())
  name     String? @db.VarChar(50)
  desc     String? @db.VarChar(255)
  immortal String? @db.VarChar(25)
  data     String? @db.LongText
}

model callback {
  callback_id Int     @id @default(autoincrement())
  description String? @db.VarChar(50)
  callbacknum String? @db.VarChar(100)
  destination String? @db.VarChar(50)
  sleep       Int?
  deptname    String? @db.VarChar(50)
  context     String  @db.VarChar(50)
}

model callrecording {
  callrecording_id   Int     @id @default(autoincrement())
  callrecording_mode String? @db.VarChar(50)
